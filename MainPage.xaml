<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ClipboardManager.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ClipboardManager"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="30" RequestedTheme="Dark">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Clipboard History" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,10" FontWeight="Bold">
            <TextBlock.Foreground>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF00C6FF" Offset="0.0" />
                    <GradientStop Color="#FF0072FF" Offset="1.0" />
                </LinearGradientBrush>
            </TextBlock.Foreground>
        </TextBlock>
        
        <Grid Grid.Row="1" Margin="0,0,15,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <AutoSuggestBox x:Name="SearchBox" QueryIcon="Find" PlaceholderText="Search history..." TextChanged="SearchBox_TextChanged" MaxWidth="400" HorizontalAlignment="Left" Width="400" VerticalAlignment="Center" />
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="DeleteSelectedButton" ToolTipService.ToolTip="Delete Selected" Click="DeleteSelectedButton_Click" Visibility="Collapsed" Margin="0,0,5,0" Width="40" Height="40" Background="Transparent" BorderThickness="0" Foreground="Red">
                    <FontIcon Glyph="&#xE74D;" FontSize="16" />
                </Button>
                <Button x:Name="CancelSelectionButton" ToolTipService.ToolTip="Cancel Selection" Click="CancelSelectionButton_Click" Visibility="Collapsed" Margin="0,0,5,0" Width="40" Height="40" Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE711;" FontSize="16" />
                </Button>
                <Button x:Name="SelectItemsButton" ToolTipService.ToolTip="Select Items" Click="SelectItemsButton_Click" Margin="0,0,10,0" Width="40" Height="40" Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE8FD;" FontSize="16" />
                </Button>
            </StackPanel>

            <ComboBox x:Name="FilterComboBox" Grid.Column="2" Margin="10,0,0,0" SelectedIndex="0" SelectionChanged="FilterComboBox_SelectionChanged" Width="150" VerticalAlignment="Center">
                <ComboBoxItem Content="All Types" Tag="All" />
                <ComboBoxItem Content="Text" Tag="Text" />
                <ComboBoxItem Content="Image" Tag="Image" />
                <ComboBoxItem Content="Files" Tag="FileDrop" />
            </ComboBox>

            <ToggleButton x:Name="SortToggleButton" Grid.Column="3" Margin="10,0,0,0" Content="Oldest First" Checked="SortToggleButton_CheckedChanged" Unchecked="SortToggleButton_CheckedChanged" VerticalAlignment="Center" />
        </Grid>
        
        <ListView x:Name="ClipboardListView" Grid.Row="2" ItemsSource="{x:Bind FilteredItems}" SelectionChanged="ClipboardListView_SelectionChanged" SelectionMode="Single">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="0,5,15,5" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="CornerRadius" Value="8" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ClipboardItem">
                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="4,1,1,1" Expanding="Expander_Expanding">
                        <Expander.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFFF0080" Offset="0.0" />
                                <GradientStop Color="#FFFF8C00" Offset="1.0" />
                            </LinearGradientBrush>
                        </Expander.BorderBrush>
                        <Expander.Header>
                            <Grid Padding="0" Margin="0" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <FontIcon Glyph="{x:Bind IconGlyph}" FontSize="28" Margin="0,0,15,0" VerticalAlignment="Center">
                                    <FontIcon.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFFF0080" Offset="0.0" />
                                            <GradientStop Color="#FFFF8C00" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </FontIcon.Foreground>
                                </FontIcon>
                                
                                <TextBlock Text="{x:Bind PreviewSnippet}" Grid.Column="1" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" VerticalAlignment="Center" FontSize="15"/>
                                
                                <TextBlock Text="{x:Bind TimestampText}" Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="15,0,15,0" FontSize="12"/>
                                <Button Grid.Column="3" ToolTipService.ToolTip="Delete" Click="DeleteButton_Click" Tag="{x:Bind Id}" Margin="0" Width="40" Height="40" Background="Transparent" BorderThickness="0" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE74D;" FontSize="16" />
                                </Button>
                            </Grid>
                        </Expander.Header>
                        
                        <Expander.Content>
                            <StackPanel Spacing="10">
                                <ScrollViewer MaxHeight="300">
                                    <StackPanel>
                                        <TextBlock Text="{x:Bind FullText, Mode=OneWay}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                        <Image Source="{x:Bind ImagePreview, Mode=OneWay}" Stretch="Uniform" MaxHeight="300" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </ScrollViewer>
                                <Button Content="Copy to Clipboard" Click="CopyButton_Click" Tag="{x:Bind Id}" HorizontalAlignment="Right" Style="{StaticResource AccentButtonStyle}"/>
                            </StackPanel>
                        </Expander.Content>
                    </Expander>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
